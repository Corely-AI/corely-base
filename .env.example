# ============================================================================
# COMMON SETTINGS
# ============================================================================
NODE_ENV=development
APP_ENV=dev
LOG_LEVEL=info

# ============================================================================
# POSTGRES DATABASE
# ============================================================================
POSTGRES_DB=corely
POSTGRES_USER=corely
POSTGRES_PASSWORD=corely
DATABASE_URL=postgresql://corely:corely@localhost:5434/corely?schema=public

# ============================================================================
# REDIS CACHE & QUEUE
# ============================================================================
REDIS_URL=redis://localhost:6379
WORKFLOW_QUEUE_DRIVER=memory
WORKFLOW_QUEUE_SECRET=
WORKFLOW_CLOUDTASKS_LOCATION=
WORKFLOW_CLOUDTASKS_QUEUE_PREFIX=
WORKFLOW_CLOUDTASKS_TARGET_BASE_URL=
WORKFLOW_CLOUDTASKS_SERVICE_ACCOUNT=

# ============================================================================
# PORTS
# ============================================================================
PORT=3000
WEB_PORT=8080
MOCK_PORT=4000
WORKER_PORT=3001

# ============================================================================
# WORKER
# ============================================================================
API_BASE_URL=http://localhost:3000
WORKER_API_SERVICE_TOKEN=
WORKER_TICK_RUNNERS=outbox,classesBilling
WORKER_BUSY_LOOP_DELAY_MS=3000

# ============================================================================
# AI PROVIDERS
# ============================================================================
AI_MODEL_PROVIDER=openai
AI_MODEL_ID=gpt-4o-mini
SPEECH_TO_TEXT_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CRM_AI_ENABLED=false
CRM_AI_V2_ANALYTICS_ENABLED=false
CRM_AI_INTENT_SENTIMENT_ENABLED=false

# ============================================================================
# EMAIL PROVIDERS
# ============================================================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM="Corely <no-reply@example.com>"
RESEND_REPLY_TO=
RESEND_WEBHOOK_SECRET=

# ============================================================================
# OBJECT STORAGE
# ============================================================================
STORAGE_PROVIDER=local
STORAGE_BUCKET=uploads
STORAGE_KEY_PREFIX=
SIGNED_URL_UPLOAD_TTL_SECONDS=600
SIGNED_URL_DOWNLOAD_TTL_SECONDS=600
MAX_UPLOAD_BYTES=52428800
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================================================
# OBSERVABILITY
# ============================================================================
OBSERVABILITY_PROVIDER=none
OBSERVABILITY_SAMPLE_RATIO=1
OBSERVABILITY_MASKING_MODE=standard
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ============================================================================
# SECURITY & AUTH
# ============================================================================
JWT_SECRET=dev-jwt-secret
WEB_BASE_URL=http://localhost:8080
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# ============================================================================
# FRONTEND (VITE)
# ============================================================================
VITE_API_BASE_URL=http://localhost:3000
VITE_API_MODE=real
VITE_MOCK_API_BASE_URL=http://localhost:4000
VITE_API_MOCK_BASE_URL=http://localhost:4000
VITE_API_URL=http://localhost:3000
VITE_PUBLIC_WEB_BASE_URL=http://localhost:8080
VITE_PORTAL_BASE_URL=http://localhost:8080
VITE_WEBSITE_RUNTIME_BASE_URL=http://localhost:8084
VITE_PUBLIC_ROOT_DOMAIN=localhost
VITE_PUBLIC_WORKSPACE_QUERY_ENABLED=true
VITE_APP_HOST=app.localhost
VITE_APP_BASE_DOMAINS=localhost
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
